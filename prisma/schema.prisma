// TRP Booking — Prisma core booking domain schema
//
// Clean database baseline.
// TypeScript/Prisma field names stay camelCase for code ergonomics.
// PostgreSQL tables, columns, and enum type names are mapped to snake_case.

 generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN

  @@map("user_role")
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  INACTIVE

  @@map("property_status")
}

enum ReservationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  EXPIRED
  BLOCKED

  @@map("reservation_status")
}

enum PaymentProvider {
  TILOPAY

  @@map("payment_provider")
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED

  @@map("payment_status")
}

enum RefundStatus {
  PENDING
  APPROVED
  FAILED
  MANUAL

  @@map("refund_status")
}

enum CalendarBlockSource {
  DIRECT_RESERVATION
  AIRBNB
  MANUAL_BLOCK
  MAINTENANCE
  COMPOSED_LISTING_DEPENDENCY
  PREPARATION_BUFFER

  @@map("calendar_block_source")
}

enum ExternalCalendarProvider {
  AIRBNB

  @@map("external_calendar_provider")
}

enum ExternalCalendarStatus {
  ACTIVE
  INACTIVE
  ERROR

  @@map("external_calendar_status")
}

enum ExternalCalendarDirection {
  IMPORT
  EXPORT
  BIDIRECTIONAL

  @@map("external_calendar_direction")
}

enum ExternalCalendarEventStatus {
  ACTIVE
  REMOVED
  CANCELLED

  @@map("external_calendar_event_status")
}

enum CalendarSyncTriggeredBy {
  CRON
  ADMIN
  SYSTEM

  @@map("calendar_sync_triggered_by")
}

enum CalendarSyncStatus {
  STARTED
  SUCCESS
  FAILED
  PARTIAL_SUCCESS

  @@map("calendar_sync_status")
}

enum EmailNotificationType {
  RESERVATION_CONFIRMED
  PAYMENT_APPROVED
  PAYMENT_FAILED
  RESERVATION_CANCELLED
  RESERVATION_DATES_UPDATED
  STAY_EXTENSION_CONFIRMED
  REFUND_PROCESSED
  ARRIVAL_INSTRUCTIONS
  ADMIN_NEW_RESERVATION

  @@map("email_notification_type")
}

enum EmailNotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED

  @@map("email_notification_status")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deletedProperties        Property[]         @relation("PropertyDeletedBy")
  deletedPropertyImages    PropertyImage[]    @relation("PropertyImageDeletedBy")
  deletedAmenities         Amenity[]          @relation("AmenityDeletedBy")
  deletedHouseRules        HouseRule[]        @relation("HouseRuleDeletedBy")
  deletedExternalCalendars ExternalCalendar[] @relation("ExternalCalendarDeletedBy")
  deletedCalendarBlocks    CalendarBlock[]    @relation("CalendarBlockDeletedBy")
  unlockedCalendarBlocks   CalendarBlock[]    @relation("CalendarBlockUnlockedBy")
  auditLogs                AdminAuditLog[]

  @@map("users")
}

model Property {
  id                    String         @id @default(cuid())
  nameEs                String         @map("name_es")
  nameEn                String         @map("name_en")
  slug                  String         @unique
  shortDescriptionEs    String         @map("short_description_es") @db.Text
  shortDescriptionEn    String         @map("short_description_en") @db.Text
  longDescriptionEs     String         @map("long_description_es") @db.Text
  longDescriptionEn     String         @map("long_description_en") @db.Text
  maxGuests             Int            @map("max_guests")
  bedrooms              Int
  bathrooms             Int
  baseNightlyPrice      Decimal        @map("base_nightly_price") @db.Decimal(10, 2)
  currency              String         @default("USD")
  status                PropertyStatus @default(DRAFT)
  checkInTime           String         @map("check_in_time")
  checkOutTime          String?        @map("check_out_time")
  isComposed            Boolean        @default(false) @map("is_composed")
  preparationDaysBefore Int            @default(0) @map("preparation_days_before")
  preparationDaysAfter  Int            @default(0) @map("preparation_days_after")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  deletedAt             DateTime?      @map("deleted_at")
  deletedById           String?        @map("deleted_by_id")

  deletedBy         User?               @relation("PropertyDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  parentComponents  PropertyComponent[] @relation("ParentProperty")
  componentOf       PropertyComponent[] @relation("ComponentProperty")
  images            PropertyImage[]
  amenities         PropertyAmenity[]
  rules             PropertyRule[]
  reservations      Reservation[]
  calendarBlocks    CalendarBlock[]
  externalCalendars ExternalCalendar[]

  @@index([status])
  @@index([deletedAt])
  @@map("properties")
}

model PropertyComponent {
  id                  String   @id @default(cuid())
  parentPropertyId    String   @map("parent_property_id")
  componentPropertyId String   @map("component_property_id")
  createdAt           DateTime @default(now()) @map("created_at")

  parentProperty    Property @relation("ParentProperty", fields: [parentPropertyId], references: [id], onDelete: Cascade)
  componentProperty Property @relation("ComponentProperty", fields: [componentPropertyId], references: [id], onDelete: Restrict)

  @@unique([parentPropertyId, componentPropertyId])
  @@index([componentPropertyId])
  @@map("property_components")
}

model PropertyImage {
  id                 String   @id @default(cuid())
  propertyId         String   @map("property_id")
  cloudinaryPublicId String?  @map("cloudinary_public_id")
  url                String
  secureUrl          String?  @map("secure_url")
  altTextEs          String   @map("alt_text_es")
  altTextEn          String   @map("alt_text_en")
  sortOrder          Int      @default(0) @map("sort_order")
  isCover            Boolean  @default(false) @map("is_cover")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  deletedById        String?  @map("deleted_by_id")

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  deletedBy User?    @relation("PropertyImageDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([propertyId, sortOrder])
  @@index([deletedAt])
  @@map("property_images")
}

model Amenity {
  id          String   @id @default(cuid())
  key         String   @unique
  nameEs      String   @map("name_es")
  nameEn      String   @map("name_en")
  icon        String
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?  @map("deleted_by_id")

  deletedBy  User?             @relation("AmenityDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  properties PropertyAmenity[]

  @@index([deletedAt])
  @@map("amenities")
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  amenityId  String   @map("amenity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Restrict)

  @@unique([propertyId, amenityId])
  @@index([amenityId])
  @@map("property_amenities")
}

model HouseRule {
  id            String   @id @default(cuid())
  key           String   @unique
  titleEs       String   @map("title_es")
  titleEn       String   @map("title_en")
  descriptionEs String   @map("description_es") @db.Text
  descriptionEn String   @map("description_en") @db.Text
  category      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?  @map("deleted_by_id")

  deletedBy  User?          @relation("HouseRuleDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  properties PropertyRule[]

  @@index([deletedAt])
  @@map("house_rules")
}

model PropertyRule {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  ruleId     String   @map("rule_id")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rule     HouseRule @relation(fields: [ruleId], references: [id], onDelete: Restrict)

  @@unique([propertyId, ruleId])
  @@index([ruleId])
  @@map("property_rules")
}

model Reservation {
  id                  String            @id @default(cuid())
  propertyId          String            @map("property_id")
  guestName           String            @map("guest_name")
  guestEmail          String            @map("guest_email")
  guestPhone          String?           @map("guest_phone")
  guestCountry        String?           @map("guest_country")
  checkInDate         DateTime          @map("check_in_date") @db.Date
  checkOutDate        DateTime          @map("check_out_date") @db.Date
  arrivalTimeEstimate String?           @map("arrival_time_estimate")
  guestCount          Int               @map("guest_count")
  status              ReservationStatus @default(PENDING_PAYMENT)
  subtotal            Decimal           @db.Decimal(10, 2)
  cleaningFee         Decimal           @default(0) @map("cleaning_fee") @db.Decimal(10, 2)
  taxes               Decimal           @default(0) @db.Decimal(10, 2)
  discounts           Decimal           @default(0) @db.Decimal(10, 2)
  total               Decimal           @db.Decimal(10, 2)
  currency            String            @default("USD")
  expiresAt           DateTime?         @map("expires_at")
  confirmedAt         DateTime?         @map("confirmed_at")
  cancelledAt         DateTime?         @map("cancelled_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  guests             ReservationGuest[]
  payments           Payment[]
  calendarBlocks     CalendarBlock[]
  emailNotifications EmailNotification[]

  @@index([propertyId, checkInDate, checkOutDate])
  @@index([status])
  @@index([guestEmail])
  @@map("reservations")
}

model ReservationGuest {
  id            String   @id @default(cuid())
  reservationId String   @map("reservation_id")
  name          String
  email         String?
  phone         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@map("reservation_guests")
}

model Payment {
  id                    String          @id @default(cuid())
  reservationId         String          @map("reservation_id")
  provider              PaymentProvider @default(TILOPAY)
  providerTransactionId String?         @map("provider_transaction_id")
  providerReference     String?         @map("provider_reference")
  status                PaymentStatus   @default(PENDING)
  amount                Decimal         @db.Decimal(10, 2)
  currency              String          @default("USD")
  paidAt                DateTime?       @map("paid_at")
  failedAt              DateTime?       @map("failed_at")
  rawPayload            Json?           @map("raw_payload")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  refunds     Refund[]

  @@index([reservationId])
  @@index([provider, providerReference])
  @@index([status])
  @@map("payments")
}

model Refund {
  id               String       @id @default(cuid())
  paymentId        String       @map("payment_id")
  providerRefundId String?      @map("provider_refund_id")
  amount           Decimal      @db.Decimal(10, 2)
  currency         String       @default("USD")
  reason           String?
  status           RefundStatus @default(PENDING)
  rawPayload       Json?        @map("raw_payload")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([paymentId])
  @@index([status])
  @@map("refunds")
}

model CalendarBlock {
  id                      String              @id @default(cuid())
  propertyId              String              @map("property_id")
  startDate               DateTime            @map("start_date") @db.Date
  endDate                 DateTime            @map("end_date") @db.Date
  source                  CalendarBlockSource
  reason                  String?
  reservationId           String?             @map("reservation_id")
  externalCalendarEventId String?             @map("external_calendar_event_id")
  parentBlockId           String?             @map("parent_block_id")
  isAdminOverrideAllowed  Boolean             @default(false) @map("is_admin_override_allowed")
  unlockedByAdminAt       DateTime?           @map("unlocked_by_admin_at")
  unlockedByAdminId       String?             @map("unlocked_by_admin_id")
  adminOverrideReason     String?             @map("admin_override_reason")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")
  deletedAt               DateTime?           @map("deleted_at")
  deletedById             String?             @map("deleted_by_id")

  property              Property               @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  reservation           Reservation?            @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  externalCalendarEvent ExternalCalendarEvent?  @relation(fields: [externalCalendarEventId], references: [id], onDelete: SetNull)
  parentBlock           CalendarBlock?          @relation("CalendarBlockParent", fields: [parentBlockId], references: [id], onDelete: SetNull)
  childBlocks           CalendarBlock[]         @relation("CalendarBlockParent")
  unlockedByAdmin       User?                   @relation("CalendarBlockUnlockedBy", fields: [unlockedByAdminId], references: [id], onDelete: SetNull)
  deletedBy             User?                   @relation("CalendarBlockDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([propertyId, startDate, endDate])
  @@index([source])
  @@index([reservationId])
  @@index([externalCalendarEventId])
  @@index([deletedAt])
  @@map("calendar_blocks")
}

model ExternalCalendar {
  id                       String                    @id @default(cuid())
  propertyId               String                    @map("property_id")
  provider                 ExternalCalendarProvider  @default(AIRBNB)
  direction                ExternalCalendarDirection @default(BIDIRECTIONAL)
  name                     String
  importUrlEncrypted       String?                   @map("import_url_encrypted") @db.Text
  exportTokenHash          String?                   @unique @map("export_token_hash")
  exportTokenLastRotatedAt DateTime?                 @map("export_token_last_rotated_at")
  isImportEnabled          Boolean                   @default(true) @map("is_import_enabled")
  isExportEnabled          Boolean                   @default(true) @map("is_export_enabled")
  lastImportStartedAt      DateTime?                 @map("last_import_started_at")
  lastImportFinishedAt     DateTime?                 @map("last_import_finished_at")
  lastExportGeneratedAt    DateTime?                 @map("last_export_generated_at")
  lastFailureCode          String?                   @map("last_failure_code")
  lastFailureMessage       String?                   @map("last_failure_message") @db.Text
  status                   ExternalCalendarStatus    @default(ACTIVE)
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  deletedAt                DateTime?                 @map("deleted_at")
  deletedById              String?                   @map("deleted_by_id")

  property  Property                  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  deletedBy User?                     @relation("ExternalCalendarDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  events    ExternalCalendarEvent[]
  syncLogs  ExternalCalendarSyncLog[]

  @@index([propertyId])
  @@index([provider, status])
  @@index([direction])
  @@index([deletedAt])
  @@map("external_calendars")
}

model ExternalCalendarEvent {
  id                 String                      @id @default(cuid())
  externalCalendarId String                      @map("external_calendar_id")
  providerEventUid   String                      @map("provider_event_uid")
  status             ExternalCalendarEventStatus @default(ACTIVE)
  summary            String?
  startDate          DateTime                    @map("start_date") @db.Date
  endDate            DateTime                    @map("end_date") @db.Date
  firstSeenAt        DateTime                    @default(now()) @map("first_seen_at")
  lastSeenAt         DateTime                    @default(now()) @map("last_seen_at")
  removedAt          DateTime?                   @map("removed_at")
  rawPayload         Json?                       @map("raw_payload")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  externalCalendar ExternalCalendar @relation(fields: [externalCalendarId], references: [id], onDelete: Cascade)
  calendarBlocks    CalendarBlock[]

  @@unique([externalCalendarId, providerEventUid])
  @@index([externalCalendarId, startDate, endDate])
  @@index([status])
  @@map("external_calendar_events")
}

model ExternalCalendarSyncLog {
  id                 String                  @id @default(cuid())
  externalCalendarId String                  @map("external_calendar_id")
  triggeredBy        CalendarSyncTriggeredBy @map("triggered_by")
  status             CalendarSyncStatus      @default(STARTED)
  startedAt          DateTime                @default(now()) @map("started_at")
  finishedAt         DateTime?               @map("finished_at")
  eventsImported     Int                     @default(0) @map("events_imported")
  eventsUpdated      Int                     @default(0) @map("events_updated")
  eventsRemoved      Int                     @default(0) @map("events_removed")
  eventsSkipped      Int                     @default(0) @map("events_skipped")
  blocksCreated      Int                     @default(0) @map("blocks_created")
  blocksUpdated      Int                     @default(0) @map("blocks_updated")
  errorCode          String?                 @map("error_code")
  errorMessage       String?                 @map("error_message") @db.Text
  createdAt          DateTime                @default(now()) @map("created_at")

  externalCalendar ExternalCalendar @relation(fields: [externalCalendarId], references: [id], onDelete: Cascade)

  @@index([externalCalendarId])
  @@index([status])
  @@index([startedAt])
  @@map("external_calendar_sync_logs")
}

model EmailNotification {
  id                String                  @id @default(cuid())
  reservationId     String                  @map("reservation_id")
  type              EmailNotificationType
  recipient         String
  locale            String
  status            EmailNotificationStatus @default(PENDING)
  providerMessageId String?                 @map("provider_message_id")
  sentAt            DateTime?               @map("sent_at")
  errorMessage      String?                 @map("error_message")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([status])
  @@index([type])
  @@map("email_notifications")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
