# TRP Booking environment template.
# Copy this file to `.env` for local Prisma CLI usage and server-side env validation.
# Copy the required values to Vercel environment variables when deploying.
#
# Do not commit `.env`, `.env.local`, or any real secret values.

# Supabase / PostgreSQL
#
# Development target:
# - Supabase organization/project: portfolio-lab
# - PostgreSQL schema: trp_booking
#
# Use the pooled connection for runtime usage when available.
# Use the direct connection for Prisma migrations when available.
#
# Keep `schema=trp_booking` in both URLs so Prisma does not use the public schema.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=trp_booking"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=trp_booking"

# Auth.js / NextAuth
#
# Generate AUTH_SECRET locally with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Local development should use AUTH_TRUST_HOST=true once Auth.js routes and admin middleware are enabled.
# Vercel/production should also use AUTH_TRUST_HOST=true unless the deployment is explicitly verified otherwise.
#
# AUTH_ALLOWED_ADMIN_EMAILS must be a comma-separated server-side allowlist.
AUTH_SECRET="CHANGE_ME_GENERATE_RANDOM_SECRET"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID="CHANGE_ME_GOOGLE_CLIENT_ID"
AUTH_GOOGLE_SECRET="CHANGE_ME_GOOGLE_SECRET"
AUTH_ALLOWED_ADMIN_EMAILS="admin@example.com"

# Optional for local development or non-standard deployments.
# Auth.js v5 usually infers the host from request headers when trusted host is enabled.
# AUTH_URL="http://localhost:3000"

# Cloudinary
#
# Phase 5.2 validates these server-side.
# Add real values to `.env` before running `npm run env:validate`.
#
# Keep these values server-side only. Do not expose the API key or API secret through NEXT_PUBLIC variables.
# Use a dedicated development folder so test assets do not mix with production assets.
CLOUDINARY_CLOUD_NAME="CHANGE_ME_CLOUDINARY_CLOUD_NAME"
CLOUDINARY_API_KEY="CHANGE_ME_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="CHANGE_ME_CLOUDINARY_API_SECRET"
CLOUDINARY_UPLOAD_FOLDER="trp-booking/dev"

# Tilopay
#
# These names map directly to the values shown in the Tilopay admin panel:
# - Api Key      -> TILOPAY_API_KEY
# - Api User     -> TILOPAY_API_USER
# - Api Password -> TILOPAY_API_PASSWORD
#
# Keep all Tilopay values server-side only. Do not expose them through NEXT_PUBLIC variables.
# Do not commit real Tilopay credentials, tokens, signatures, or provider payloads.
#
# Local development callback URLs may use localhost.
# Vercel preview/production callback URLs must use HTTPS.
TILOPAY_ENVIRONMENT="sandbox"
TILOPAY_API_KEY="CHANGE_ME_TILOPAY_API_KEY"
TILOPAY_API_USER="CHANGE_ME_TILOPAY_API_USER"
TILOPAY_API_PASSWORD="CHANGE_ME_TILOPAY_API_PASSWORD"
TILOPAY_REDIRECT_URL="http://localhost:3000/api/payments/tilopay/redirect"
TILOPAY_SUCCESS_URL="http://localhost:3000/reservas/pago/exitoso"
TILOPAY_CANCEL_URL="http://localhost:3000/reservas/pago/cancelado"
TILOPAY_ERROR_URL="http://localhost:3000/reservas/pago/error"
TILOPAY_WEBHOOK_URL="http://localhost:3000/api/payments/tilopay/webhook"

# Resend / transactional email
#
# Keep EMAIL_DELIVERY_MODE=disabled until a Resend API key and verified sending domain are ready.
# In test mode, every intended recipient is replaced by EMAIL_TEST_RECIPIENT.
# Production mode requires HTTPS EMAIL_PUBLIC_BASE_URL and does not allow a test override.
# Keep all values server-side only. Never use NEXT_PUBLIC variables for email configuration.
EMAIL_DELIVERY_MODE="disabled"
RESEND_API_KEY=""
EMAIL_FROM_ES="Tu Refugio Perfecto <reservas@turefugioperfecto.com.gt>"
EMAIL_FROM_EN="Tu Refugio Perfecto <reservations@turefugioperfecto.com.gt>"
EMAIL_REPLY_TO_ES="reservas@turefugioperfecto.com.gt"
EMAIL_REPLY_TO_EN="reservations@turefugioperfecto.com.gt"
EMAIL_ADMIN_RECIPIENTS="admin@turefugioperfecto.com.gt"
EMAIL_ADMIN_LOCALE="es"
EMAIL_PUBLIC_BASE_URL="http://localhost:3000"
EMAIL_TEST_RECIPIENT=""

# Airbnb iCal / Vercel Cron
#
# Phase 7.5 uses CRON_SECRET to protect /api/cron/sync-airbnb-calendars
# and Phase 8.5.1 uses it to protect /api/cron/expire-pending-reservation-holds.
#
# Generate a strong value locally with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Keep this value server-side only. Do not expose it through NEXT_PUBLIC variables.
CRON_SECRET="CHANGE_ME_GENERATE_RANDOM_CRON_SECRET"

# Optional early-development fallback for resolving Airbnb import URLs server-side.
# Prefer encrypted database-backed resolution once an admin settings flow exists.
# Do not commit real Airbnb iCal URLs or tokens.
# AIRBNB_ICAL_IMPORT_URLS_JSON="{\"external_calendar_id\":\"https://calendar.airbnb.com/calendar/ical/CHANGE_ME.ics?s=CHANGE_ME\"}"
